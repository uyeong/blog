<!doctype html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title><%= page.title ? `${page.title} | ` : '' %><%= config.title %></title>
  <% if (page.description) { %>
    <meta name="description" content="<%= page.description %>">
  <% } else { %>
    <meta name="description" content="<%= config.description %>">
  <% } %>
  <% if (page.tags && page.tags.data.length > 0) { %>
    <meta name="keywords" content="<%= config.keywords %>,<%= page.tags.data.map(({name}) => name).join(',') %>">
  <% } else { %>
    <meta name="keywords" content="<%= config.keywords %>">
  <% } %>
  <% if (config.author) { %>
    <meta name="author" content="<%= config.author %>">
  <% } %>
  <% const canonicalUrl = full_url_for(page.path || url_for(page.permalink || '/')); %>
  <link rel="canonical" href="<%= canonicalUrl %>">

  <script type="application/ld+json">
    <%- JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: config.title,
      url: full_url_for('/'),
      inLanguage: config.language || 'ko'
    }) %>
  </script>

  <% if (page.layout === 'post') { %>
    <% const coverUrl = page.cover ? full_url_for(url_for(`images/${page.slug}/${page.cover}`)) : null; %>
    <script type="application/ld+json">
      <%- JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: page.title,
        description: page.description || config.description,
        datePublished: page.date ? page.date.toISOString() : undefined,
        dateModified: page.updated ? page.updated.toISOString() : (page.date ? page.date.toISOString() : undefined),
        author: config.author ? { '@type': 'Person', name: config.author } : undefined,
        mainEntityOfPage: canonicalUrl,
        image: coverUrl ? [coverUrl] : undefined
      }) %>
    </script>
  <% } %>

  <% if (theme.rss){ %>
    <link rel="alternate" href="<%- theme.rss %>" title="<%= config.title %>" type="application/atom+xml">
  <% } %>
  <% if (theme.favicon){ %>
    <link rel="icon" href="<%- theme.favicon %>">
  <% } %>
  <%- open_graph({twitter_id: theme.twitter, twitter_site: url}) %>
  <%- css('//cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css') %>
  <%- css('//cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css') %>
  <%- css('//cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css') %>
  <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" media="(prefers-color-scheme: dark)">
  <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css" media="(prefers-color-scheme: no-preference), (prefers-color-scheme: light)">
  <%- css('//cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.css') %>
  <%- css('style') %>
  <link rel="stylesheet" href="<%- url_for('/dark.css') %>" media="(prefers-color-scheme: dark)">
</head>
<body>
