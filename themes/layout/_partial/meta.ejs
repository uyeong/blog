<div class="meta">
  <div class="meta__datetime">
    <i class="fa fa-clock-o" aria-hidden="true"></i>
    <time datetime="<%= writeAt.format() %>">
      <%= writeAt.format('YYYY.MM.DD') %>
    </time>
  </div>
  <div class="meta__categories ellipsis">
    <i class="fa fa-map-marker" aria-hidden="true"></i>
    <% if(categories && categories.length > 0) { %>
      <div class="meta__category-list">
        <% categories.map((category, index) => { %>
          <a href="<%= url_for(category.path) %>" class="meta__category-list-item">
            <span><%= category.name %></span>
          </a>
          <% if (categories.length - 1 !== index) { %>
            <span>&nbsp/ </span>
          <% } %>
        <% }); %>
      </div>
    <% } %>
  </div>
  <% 
    const gaViews = site?.data?.ga_views?.pageViews || {};
    const pagePath = page && page.path ? url_for(page.path) : null;
    const pagePathNoSlash = pagePath ? pagePath.replace(/\/$/, '') : null;
    const views = pagePath ? (gaViews[pagePath] ?? gaViews[pagePathNoSlash] ?? null) : null;
  %>
  <% if (views !== null) { %>
    <div class="meta__views">
      <i class="fa fa-eye" aria-hidden="true"></i>
      <span><%= Number(views).toLocaleString('ko-KR') %></span>
    </div>
  <% } %>
</div>
